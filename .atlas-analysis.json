{
  "projectType": "sdk-library",
  "projectName": "GodotNWS",
  "projectDescription": "A Godot 4 plugin that wraps the U.S. National Weather Service API to provide forecast, observation, alert, radar, and weather imagery data via a simple autoload singleton.",
  "theme": "palm",
  "primaryColor": "#1A6FBF",
  "lightColor": "#4DA6FF",
  "darkColor": "#0D4A8A",
