  "keyFeatures": [
    "Autoload singleton `Nws` registers automatically when the plugin is enabled",
    "Location setup via explicit coordinates or automatic IP geolocation",
    "Daily and hourly forecast fetching with optional icon images",
    "Current weather observations including temperature, wind, precipitation, and pressure",
    "Active weather alerts with full severity, urgency, and timeline metadata",
    "Animated radar GIF retrieval (base reflectivity and base velocity)",
    "Graphicast forecast images and forecast chart GIFs from NOAA",
    "Weather stories from the local NWS forecast office",
    "Radio broadcast text retrieval",
    "US warning map and drought monitor images",
    "Signal-driven async API — all responses are delivered via Godot signals"
  ],
  "publicApiSurface": [
    "Nws.setup(latitude: float, longitude: float)",
    "Nws.setup_ip()",
    "Nws.fetch_forecast(fetch_images: bool)",
    "Nws.fetch_hourly_forecast(fetch_images: bool)",
    "Nws.fetch_current_observations(fetch_icon: bool)",
    "Nws.fetch_alerts()",
    "Nws.fetch_radar_gif(velocity: bool)",
    "Nws.fetch_forecast_chart(index: int)",
    "Nws.fetch_graphicast(index: int)",
    "Nws.fetch_weather_stories()",
    "Nws.fetch_radio_broadcast()",
    "Nws.fetch_us_warning_map()",
    "Nws.fetch_drought_monitor()",
    "signal location_setup_complete",
    "signal forecast_fetched(periods: Array[ForecastPeriod])",
    "signal hourly_forecast_fetched(periods: Array[HourlyForecastPeriod])",
    "signal observations_fetched(observations: ObservationPacket)",
    "signal alerts_fetched(alerts: Array[Alert])",
    "signal radar_fetched(image_buffer)",
    "signal chart_fetched(image_buffer)",
    "signal graphicast_fetched(image, index, last_modified)",
    "signal weather_stories_fetched(stories: Array[WeatherStory])",
    "signal radio_broadcast_fetched(Paragraphs: Array[String])",
    "signal drought_fetched(image)",
    "signal us_map_fetched(image)",
    "class ForecastPeriod",
    "class HourlyForecastPeriod",
    "class ObservationPacket",
    "class Alert",
    "class WeatherStory"
  ]
}
